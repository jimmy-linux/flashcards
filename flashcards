        )

async def get_new_id():
    last_id = 0
    async with aiosqlite.connect(f'{home_dir}/.cache/fls/flashcards.db') as db:
        await db.execute('create table if not exists flashcards (id int, front mediumtext, back mediumtext, lvl int, tags, timestamp int)')
        await db.commit()
        async with db.execute('select MAX(id) from flashcards') as cursor:
            async for row in cursor:
                last_id = row[0]
    if type(last_id) != int:
        async with aiosqlite.connect(f'{home_dir}/.cache/fls/flashcards.db') as db:
            await db.execute(f'insert into flashcards(id, front, back, lvl, tags, timestamp) values (-2, "meta", "enabled", 11, json("[]"), {time.time()})')
            await db.commit()
            await db.execute(f'insert into flashcards(id, front, back, lvl, tags, timestamp) values (-1, "meta", "disabled", 11, json("[]"), {time.time()})')
            await db.commit()
        return 0
    else:
        return last_id + 1

