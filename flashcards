lvl = (
        0,                      # 0 - immediately
        60 * 20,                # 1 - 20 mins
        60 * 60,                # 2 - 1 hr
        60 * 60 * 9,            # 3 - 9 hrs
        60 * 60 * 24,           # 4 - next day
        60 * 60 * 24 * 2,       # 5 - 2 days
        60 * 60 * 24 * 6,       # 6 - 6 days
        60 * 60 * 24 * 14,      # 7 - 2 weeks
        60 * 60 * 24 * 30,      # 8 - 1 month
        60 * 60 * 24 * 30 * 2,  # 9 - 2 months
