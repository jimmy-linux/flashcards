async def get_active_cards():
    cards = []
    now = int(time.time())
    async with aiosqlite.connect(f'{home_dir}/.cache/fls/flashcards.db') as db:
        async with db.execute('select * from flashcards') as cursor:
            async for row in cursor:
                card = {
                        'id': row[0],
                        'front': row[1],
                        'back': row[2],
                        'lvl': row[3],
                        'tags': row[4],
                        'timestamp': row[5]
                        }
                if now - card['timestamp'] >= lvl[card['lvl']]:
                    cards.append(card)
    return cards

def erase_line():
    print("\033[A\033[2K\033[A")    # erase current line: [A cursor up, [2K erase whole line

async def memorize(cards):
    now = int(time.time())
    should_exit = False
    random.shuffle(cards)
    for card in cards:
        print(card["front"])
        front = True
        while True:
            user_input = click.getchar()
            erase_line()
            if user_input == 'f':
                if front:
                    print(card["back"])
                    front = False
                else:
                    print(card["front"])
                    front = True
            elif user_input == 'd':
                await delete_card(card)
                cards.remove(card)
                break
            elif user_input == 'y':
                while lvl[card["lvl"]] < now - card["timestamp"]:
                    card["lvl"] += 1
                break
            elif user_input == 'n':
                card["lvl"] = 0
                break
            else:
                should_exit = True
                break
        card["timestamp"] = now
        if should_exit:
            break
    await update_db(cards)
    if should_exit:
        exit()
    return cards

async def update_db(cards):
    async with aiosqlite.connect(f'{home_dir}/.cache/fls/flashcards.db') as db:
        for row in cards:
            await db.execute(
                    f'update flashcards set lvl = {row['lvl']} where id = "{row['id']}"')
            await db.commit()
            await db.execute(
                    f'update flashcards set timestamp = {row['timestamp']} where id = "{row['id']}"')
            await db.commit()
            await db.execute(
                    f"""update flashcards set tags = '{row["tags"]}' where id = '{row["id"]}'""")
            await db.commit()
            await db.execute(
                    f"""update flashcards set back = '{row["back"]}' where id = '{row["id"]}'""")
            await db.commit()

async def delete_card(card):
    async with aiosqlite.connect(f'{home_dir}/.cache/fls/flashcards.db') as db:
        await db.execute(
                f'delete from flashcards where id = "{card['id']}"')
        await db.commit()

